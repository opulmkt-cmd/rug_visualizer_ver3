# Firebase Configuration (Private on server, fetched by client)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_FIRESTORE_DATABASE_ID=

# Shopify Admin API (Required for dynamic pricing and custom images)
# Create a Custom App in Shopify Admin -> Settings -> App and sales channels -> Develop apps
# Enable "write_draft_orders" and "read_products" scopes
SHOPIFY_ADMIN_ACCESS_TOKEN=

# Shopify Storefront API
VITE_SHOPIFY_STORE_DOMAIN=your-shop-name.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# ImgBB (Alternative Image Storage)
IMGBB_API_KEY=

GEMINI_API_KEY=
