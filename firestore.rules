rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: designs
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required) - UID of the owner
    //   - name: string (required) - Name of the design
    //   - imageUrl: string (required) - URL of the generated image
    //   - prompt: string (optional) - Prompt used for generation
    //   - config: map (required) - RugConfig object
    //   - status: string (optional) - Status of the design (e.g., 'Saved')
    //   - folderId: string (optional) - ID of the project folder
    //   - createdAt: timestamp (required) - Creation time
    //
    // Collection: projects
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required) - UID of the owner
    //   - name: string (required) - Name of the project
    //   - createdAt: timestamp (required) - Creation time
    //   - designIds: list (optional) - List of design IDs in this project
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email in [
           'aimanaimlengineer@gmail.com',
           'adilabbas812@gmail.com',
           'aimanmaniyar20@gmail.com',
           'adilabbas@gmail.com',
           'aimanmaniyar28@gmail.com'
         ] && request.auth.token.email_verified == true));
    }

    function isRecent(time) {
      return time is timestamp &&
        time > request.time - duration.value(5, 'm') &&
        time < request.time + duration.value(5, 'm');
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*"));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidRugConfig(config) {
      return config is map &&
        config.prompt is string &&
        config.colors is list &&
        config.materialTypes is list &&
        config.width is number &&
        config.length is number &&
        config.construction is string &&
        config.pileType is string &&
        config.pileHeight is string &&
        config.surfaceFinishes is list &&
        config.seed is number;
    }

    function isValidDesign(data) {
      return hasRequiredFields(['userId', 'name', 'imageUrl', 'config', 'createdAt']) &&
        hasOnlyAllowedFields(['userId', 'name', 'imageUrl', 'prompt', 'config', 'status', 'folderId', 'createdAt']) &&
        data.userId == request.auth.uid &&
        isValidString('name', 1, 1000) &&
        isValidUrl(data.imageUrl) &&
        isValidRugConfig(data.config) &&
        data.createdAt is timestamp;
    }

    function isValidProject(data) {
      return hasRequiredFields(['userId', 'name', 'createdAt']) &&
        hasOnlyAllowedFields(['userId', 'name', 'createdAt', 'designIds']) &&
        data.userId == request.auth.uid &&
        isValidString('name', 1, 100) &&
        data.createdAt is timestamp &&
        (!('designIds' in data) || data.designIds is list);
    }

    function isValidDesignUpdate(data) {
      return isValidDesign(data) &&
        data.userId == resource.data.userId &&
        data.createdAt == resource.data.createdAt;
    }

    function isValidProjectUpdate(data) {
      return isValidProject(data) &&
        data.userId == resource.data.userId &&
        data.createdAt == resource.data.createdAt;
    }

    function isValidPrompt(data) {
      return hasRequiredFields(['userId', 'text', 'createdAt']) &&
        data.userId == request.auth.uid &&
        data.text is string && data.text.size() > 0 && data.text.size() < 2000 &&
        data.createdAt is timestamp;
    }

    function isValidOrder(data) {
      return hasRequiredFields(['userId', 'type', 'status', 'amount', 'createdAt']) &&
        data.userId == request.auth.uid &&
        data.type in ['Rug Order', 'Plan Upgrade', 'Deposit'] &&
        data.status in ['Pending', 'Paid', 'Processing', 'Cancelled'] &&
        data.amount is number &&
        data.createdAt is timestamp;
    }

    function isValidUser(data) {
      return data.uid == request.auth.uid &&
        data.credits is number &&
        data.tier is string &&
        data.role is string &&
        data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /designs/{designId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidDesign(request.resource.data);
      allow update: if isAuthenticated() && isValidDesignUpdate(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidProject(request.resource.data);
      allow update: if isAuthenticated() && isValidProjectUpdate(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /prompts/{promptId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /sample_requests/{requestId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
        (request.resource.data.role == 'user' || isAdmin());
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
        (request.resource.data.role == resource.data.role || isAdmin());
    }
  }
}
